# AutoApply Environment Configuration
# Copy this to .env and fill in your values

# Nova Act
NOVA_ACT_API_KEY=export NOVA_API_KEY= 

# AWS / Bedrock
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://autoapply:password@localhost:5432/autoapply

# App
SECRET_KEY=your_secret_key_here_change_in_production
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# S3 (optional for demo, used for resume storage)
S3_BUCKET_NAME=autoapply-resumes-buchim
S3_REGION=us-east-1

# Job Search Config
MAX_PARALLEL_SESSIONS=3
APPLICATION_DELAY_SECONDS=2
